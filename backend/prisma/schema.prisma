generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(CITIZEN)
  createdAt DateTime @default(now())

  complaints      Complaint[]
  aiConversations AIConversation[]
}

enum Role {
  CITIZEN
  AUTHORITY
  ADMIN
}

model Authority {
  id           String   @id @default(uuid())
  name         String
  type         String // e.g. "NHAI", "PWD", "MUNICIPAL"
  contactEmail String
  jurisdiction Json? // GeoJSON Polygon for jurisdictional area

  roads      Road[]
  complaints Complaint[]
}

model Road {
  id          String   @id @default(uuid())
  name        String
  type        String // e.g. "Highway", "Arterial", "Local"
  status      String   @default("Active")
  authorityId      String
  geometry         Json // GeoJSON LineString for road path
  budgetSanctioned Float? // In Crores (e.g., 4.2)
  budgetSpent      Float? // In Crores (e.g., 1.8)
  contractor       String?
  startLat         Float?
  startLng         Float?
  endLat           Float?
  endLng           Float?

  authority  Authority   @relation(fields: [authorityId], references: [id])
  complaints Complaint[]
}

model Complaint {
  id          String   @id @default(uuid())
  userId      String
  roadId      String?
  authorityId String?
  issueType   String
  severity    String
  description String
  status      ComplaintStatus @default(PENDING)
  latitude    Float
  longitude   Float
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id])
  road      Road?      @relation(fields: [roadId], references: [id])
  authority Authority? @relation(fields: [authorityId], references: [id])
}

enum ComplaintStatus {
  PENDING
  ROUTED
  IN_PROGRESS
  RESOLVED
  REJECTED
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String
  prompt    String
  response  String
  context   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
